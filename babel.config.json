{
  "targets": "defaults",
  "plugins": [
    ["@babel/plugin-transform-class-properties"],
    [
      "babel-plugin-transform-rewrite-imports",
      {
        "appendExtension": ".js",
        "recognizedExtensions": [".js", ".jsx", ".d.ts", ".ts", ".tsx", ".json"]
      }
    ],
    [
      "polyfill-corejs3",
      {"method": "usage-global"}
    ]
  ],
  "presets": [
    ["@babel/preset-env"],
    ["@babel/preset-typescript"]
  ]
}
